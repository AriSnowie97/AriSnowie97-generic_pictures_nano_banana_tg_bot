# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google AI Studio API Key (get from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# Webhook URL for production (Railway will provide this automatically)
# Leave empty for local polling mode
WEBHOOK_URL=

# Port for webhook server (Railway sets this automatically)
PORT=8080
